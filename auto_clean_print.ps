%!PS

% this postscript tries to replicate the EPSON EcoTank Test Print Pattern and prints it in a grid based on NTH variable
% automatically calculates grid size: DIN A4 has 4x7 grid (with padding 10) = 28 patterns per page, 56 per sheet (year has max 53 weeks)
%
% for each print increment the /NTH and update /DATESTRING with a script and send the ps file to the printer
% use '-o sides=two-sided-long-edge' to auto 

/NTH 1 def % nth print
/DATESTRING (2025-12-09) def

% Page Size: 72points -> 1 inch
/PAGE_W 595.28 def
/PAGE_H 841.89 def
<< /PageSize [PAGE_W PAGE_H] >> setpagedevice


% print stack, stack is 'Last In First Out'
% USAGE: '(hello) NTH debug'
/debug {
    /Menlo-Regular findfont 20 scalefont setfont
    10 10 moveto
    
    count /n exch def % n = number of items on the stack

    0 1 n 1 sub {
        pop % pop the loop index
        10 string cvs show  % 10 should be string width, convertToString, show last stack item
        (|) show
    } for
} def


% EPSON PrecisionCore print head has size/height of 1.33 inches: (84.7 microns between nozzles)

% EPSON TestPrint Pattern:
%   height: 1.33 inch -> 95,76 points -> 24 cells -> single heigth 3.99 (quick maths)
%   width: 0.85 inch -> 61,2 points in 16 steps (manually measured)
%   24 cells x 16 steps = 400 nozzles (black), 8 * 16 = 128 nozzles (colors)

% 72points -> 1 inch
/CELL_H { 1.33 72 mul 24 div } def          % cell height
/CELL_H_N { CELL_H -1 mul } def             % cell height negative
/CELL_H_N2 { CELL_H_N 2 mul } def           % cell height negative 2 times to go to next starting point, see /drawCells
/CELL_W { 0.85 72 mul } def                 % cell width
/CELL_W_N { 0.85 72 mul -1 mul } def        % cell width negative

/PATTERN_HEIGHT { CELL_H 24 mul } def
/PATTERN_WIDTH { CELL_W 2 mul 0.2 add } def
/PATTERN_PADDING 10 def   % can be adjusted

/ROWS_MAX { PAGE_H PATTERN_PADDING sub PATTERN_HEIGHT PATTERN_PADDING add div cvi } def % calculate the max rows, we remove one padding from the page size so we calculate with a minimum padding all around
/COLUMNS_MAX { PAGE_W PATTERN_PADDING sub PATTERN_PADDING sub PATTERN_WIDTH PATTERN_PADDING add div cvi } def % calculate the max columns, we remove one padding from the page size so we calculate with a minimum padding all around
/GRID_MAX { ROWS_MAX COLUMNS_MAX mul cvi } def % cvi = ConvertToInteger
/GRID_HEIGHT { PATTERN_HEIGHT PATTERN_PADDING add ROWS_MAX mul PATTERN_PADDING sub } def % n-1 paddings!
/GRID_WIDTH { PATTERN_WIDTH PATTERN_PADDING add COLUMNS_MAX mul PATTERN_PADDING sub } def % n-1 paddings!

/GRID_PADDING_LEFT { PAGE_W GRID_WIDTH sub 2 div } def
/GRID_PADDING_BOTTOM { PAGE_H GRID_HEIGHT sub 2 div PATTERN_HEIGHT add } def % pattern origin is top left, page origin bottom left. so we have to add pattern height at end but without padding


% Draws rlineto in 16 steps instead of straight line
% STACK: w h
/rlineto_16_steps {
    /step_height exch 16 div def
    /step_width exch 16 div def

    % 16 steps
    0 1 15 {
        pop % remove loop index from stack
        step_width 0 rlineto % horizontal step
        0 step_height rmoveto % move to next step start
    } for
} def

% origin: top left
% lattice drawn from top to bottom
% STACK: n x y r g b
/drawCells {
    setrgbcolor % consumes r g b
    moveto % consumes x y
    /CELL_AMOUNT exch def % consumes n

    CELL_W CELL_H_N rlineto_16_steps % top line

    0 1 CELL_AMOUNT 1 sub {
        pop % remove loop index from stack
        0 CELL_H_N rlineto % right line
        CELL_W_N CELL_H rlineto_16_steps % bottom line
        0 CELL_H rlineto % left line
        CELL_W CELL_H_N2 rmoveto % back to start point ( bottom right ) for next loop
    } for
    stroke
} def

% draws black yellow magenta cyan lattices. black has 24 cells, others have 7
% STACK: n
/drawNthPattern {
    % Calculate X and Y Coordinates (Top Left)
    /n exch def % nth pattern number from stack as variable
    /NTH_MAX_GRID { n GRID_MAX mod } def  % if n over max grid size (grid full), start at 0
    /PATTERN_ROW { NTH_MAX_GRID COLUMNS_MAX div cvi } def
    /PATTERN_COLUMN { NTH_MAX_GRID COLUMNS_MAX mod } def  % NTH starts at 0

    /INVERTED_ROW { ROWS_MAX 1 sub PATTERN_ROW sub } def % invert the column to start from the top left instead of bottom left (origin)
    % /INVERTED_ROW { PATTERN_ROW } def % invert the column to start from the top left instead of bottom left (origin)

    /x { PATTERN_COLUMN PATTERN_WIDTH PATTERN_PADDING add mul GRID_PADDING_LEFT add } def
    /y { INVERTED_ROW PATTERN_HEIGHT PATTERN_PADDING add mul GRID_PADDING_BOTTOM add } def
    
    gsave

    % draw lattices
    23  x                       y                           0 0 0 drawCells   % black
    %               +0.2 because printer doesnt print the lines separately under 0.2
    6   x CELL_W add 0.2 add    y                           1 1 0 drawCells   % yellow
    6   x CELL_W add 0.2 add    y CELL_H_N 8.5 mul add      1 0 1 drawCells   % magenta
    6   x CELL_W add 0.2 add    y CELL_H_N 17 mul add       0 1 1 drawCells   % cyan

    % draw date
    x CELL_W 1.3 mul add y CELL_H_N 8.5 mul add moveto
    0 0 0 setrgbcolor
    -3.75172907 rotate
    DATESTRING show

    grestore
} def


% draws big BYMC colors rectangles to purge colors
/drawPrintPurge {
    % /x PAGE_W 6 div def
    % /y PAGE_H 4 div def
    % /height PAGE_H 2 div def
    % /width PAGE_W 6 div def

    % 0 0 0 setrgbcolor   x                   y width height rectfill
    % 1 1 0 setrgbcolor   x width 1 mul add   y width height rectfill
    % 1 0 1 setrgbcolor   x width 2 mul add   y width height rectfill
    % 0 1 1 setrgbcolor   x width 3 mul add   y width height rectfill

    /x PAGE_W 6 div def
    /y 50 def
    /height PATTERN_HEIGHT def
    /width PAGE_W 1.5 div def
    
    0 1 1 setrgbcolor x y height 0 mul add width height rectfill
    1 0 1 setrgbcolor x y height 1 mul add width height rectfill
    1 1 0 setrgbcolor x y height 2 mul add width height rectfill
    0 0 0 setrgbcolor x y height 3 mul add width height rectfill
    
    /Helvetica findfont 24 scalefont setfont
    /text (THIS SIDE UP) def
    /textWidth text stringwidth pop def % pop y part, so only width remains
    PAGE_W textWidth sub 2 div 25 moveto
    text show
} def


% if first NTH of 2nd page, print purge rectangles on first page first and then print pattern on second page. USE lp command with  '-o sides=two-sided-long-edge'
NTH 28 eq {
    % drawPrintPurge
    showpage
} if

% print nth pattern
0.1 setlinewidth
/Menlo-Regular findfont 4 scalefont setfont
NTH drawNthPattern % calc x and y from nth and draw


% Shows all possible patterns per page
0 1 GRID_MAX { drawNthPattern } for

% Page Border
% 0 0 PAGE_W PAGE_H rectstroke

showpage